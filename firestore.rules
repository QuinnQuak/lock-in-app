rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Owner-only access: a signed-in user can read/write their own
    // users/{uid} document and everything nested under it (e.g. sessions).
    // Stage 3 (friend-visible allowlists) will deliberately loosen reads.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
