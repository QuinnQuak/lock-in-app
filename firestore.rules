rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // A friendRequest's mere existence at id "fromUid_toUid" *is* its
    // pending state — there's no separate status field. This lets the
    // reciprocal friends-doc write below key off it directly instead of
    // needing a status flip to be visible mid-batch (Firestore evaluates
    // a batch's rules against the pre-batch state, so a status change
    // earlier in the same batch isn't visible to a later write in it).
    function existsPendingRequest(fromUid, toUid) {
      return exists(/databases/$(database)/documents/friendRequests/$(fromUid + '_' + toUid));
    }

    function isFriendOf(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)/friends/$(request.auth.uid));
    }

    function isGroupMember(groupId) {
      return request.auth.uid in
        get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    match /users/{uid} {
      // Owners can always read/write their own doc. Friends can read it
      // too -- this is what makes the allowlist friend-visible, the whole
      // point of Stage 3. Friends can never write.
      allow read: if isSignedIn() && (request.auth.uid == uid || isFriendOf(uid));
      allow write: if isSignedIn() && request.auth.uid == uid;

      // Session history isn't part of the transparency mechanic -- it's the
      // private source of truth for the owner's own stats, stays owner-only.
      // The friend-visible feed is the separate activity stream below.
      match /sessions/{sessionId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // Stage 5 social feed: one doc per finished lock-in, the events
      // surfaced to friends. Reads open to friends via the same isFriendOf
      // gate as the profile doc; only the owner ever writes their own.
      match /activity/{eventId} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isFriendOf(uid));
        allow write: if isSignedIn() && request.auth.uid == uid;

        // Kudos: one doc per reactor, id == reactorUid. A friend may create
        // or remove only their own kudos (never for someone else, never on
        // their own post); owner and friends read the tally. Same rules-only
        // multi-party pattern as friendRequests -- no Cloud Function.
        match /kudos/{reactorUid} {
          allow read: if isSignedIn() && (request.auth.uid == uid || isFriendOf(uid));
          allow create: if isSignedIn() && request.auth.uid == reactorUid &&
            reactorUid != uid && isFriendOf(uid) &&
            request.resource.data.reactorUid == reactorUid;
          allow delete: if isSignedIn() && request.auth.uid == reactorUid;
        }
      }

      match /friends/{friendUid} {
        allow read, delete: if isSignedIn() && request.auth.uid == uid;

        // The owner can always write their own friends list. The *other*
        // party in a request they just accepted may also create the
        // reciprocal doc (their own uid, under the sender's subcollection)
        // -- this is what makes friendship symmetric with no Cloud Function.
        allow create: if isSignedIn() &&
          (request.auth.uid == uid ||
           (request.auth.uid == friendUid && existsPendingRequest(uid, friendUid)));
      }
    }

    // Public directory: lets a signed-in user look someone up by email to
    // send a friend request, without exposing the private users/{uid} doc.
    match /userSearch/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // App-wide focus presence: state (LOCKED_IN/BREAK/IDLE) + displayName +
    // last-seen, written by the owner's foreground service each tick. Read is
    // open to any signed-in user because both consumers need it -- a friends
    // list AND a group header (whose co-members aren't necessarily friends) --
    // and the payload is low-sensitivity, same posture as userSearch. Only the
    // owner ever writes their own presence.
    match /presence/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // One doc per (fromUid, toUid) pair, id "fromUid_toUid". Only the
    // sender can create it; either party can read or delete it (accepting
    // deletes it as a final cleanup step, declining just deletes it).
    match /friendRequests/{requestId} {
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.fromUid &&
        request.resource.data.fromUid != request.resource.data.toUid &&
        requestId == request.resource.data.fromUid + '_' + request.resource.data.toUid;

      allow read, delete: if isSignedIn() &&
        request.auth.uid in [resource.data.fromUid, resource.data.toUid];
    }

    // Membership is owner-managed (owner picks from their friends at
    // creation or adds more later) -- no separate join/accept step for
    // this pass, documented as a scope simplification.
    match /groups/{groupId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberUids;
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.ownerUid &&
        request.auth.uid in request.resource.data.memberUids;

      // Management (Stage 8 step 2):
      //  - Owner: full control over any field.
      //  - Admin (in adminUids): may edit name / muteApprovalCount / memberUids,
      //    but NOT ownerUid or the adminUids roster -- promotion/demotion and
      //    ownership stay owner-only so an admin can't self-perpetuate or seize
      //    the group.
      //  - Any non-owner member: may only remove themselves (leave), stripping
      //    just their own uid from memberUids (and adminUids) and touching
      //    nothing else. The owner leaves by transferring or deleting.
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerUid ||
        (request.auth.uid in resource.data.get('adminUids', []) &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.get('adminUids', []) == resource.data.get('adminUids', [])) ||
        (request.auth.uid != resource.data.ownerUid &&
          request.auth.uid in resource.data.memberUids &&
          request.resource.data.memberUids == resource.data.memberUids.removeAll([request.auth.uid]) &&
          request.resource.data.get('adminUids', []) == resource.data.get('adminUids', []).removeAll([request.auth.uid]) &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.muteApprovalCount == resource.data.muteApprovalCount)
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerUid;

      // Ephemeral live rooms inside a group. Any member can open a lobby, see
      // the group's lobbies, and close one (best-effort cleanup when the last
      // member leaves). Presence is the lobbyId-tagged liveStatus below, not
      // stored on the lobby doc.
      match /lobbies/{lobbyId} {
        allow read, create, update, delete: if isSignedIn() && isGroupMember(groupId);
      }

      // Group chat: any member reads the history; a member can only post as
      // themselves. Messages are immutable once sent (no update/delete).
      match /messages/{messageId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow create: if isSignedIn() && isGroupMember(groupId) &&
          request.auth.uid == request.resource.data.senderUid;
      }

      // Live per-member compliance state during a group session. Each
      // member writes only their own doc; any member can read the group's.
      match /liveStatus/{uid} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
        allow write: if isSignedIn() && request.auth.uid == uid &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
      }

      // A breaker asking the group to silence their alarm. Same shape as
      // liveStatus: only the breaker writes their own request doc, any
      // member can see it (they're the ones being asked).
      match /muteRequests/{uid} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow write: if isSignedIn() && request.auth.uid == uid && isGroupMember(groupId);
      }

      // One doc per (breaker, approver) pair, id "breakerUid_approverUid".
      // Only the approver can create their own approval, and never for
      // themselves -- otherwise a breaker could self-approve past the
      // room's threshold, which would gut the whole mechanic. Either party
      // may delete it (the breaker cleans up when the break ends).
      match /muteApprovals/{approvalId} {
        allow read: if isSignedIn() && isGroupMember(groupId);

        allow create: if isSignedIn() && isGroupMember(groupId) &&
          request.auth.uid == request.resource.data.approverUid &&
          request.resource.data.approverUid != request.resource.data.breakerUid &&
          approvalId == request.resource.data.breakerUid + '_' + request.resource.data.approverUid;

        allow delete: if isSignedIn() &&
          request.auth.uid in [resource.data.breakerUid, resource.data.approverUid];
      }
    }
  }
}
